{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Kikitan (UI + Server)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-and-vite",
            "program": "${workspaceFolder}/KikitanTranslator.Photino/bin/Debug/net9.0/KikitanTranslator.Photino.dll",
            "args": [],
            "cwd": "${workspaceFolder}/KikitanTranslator.Photino",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/KikitanTranslator.Console/bin/Debug/net9.0/KikitanTranslator.Console.dll",
            "args": [],
            "cwd": "${workspaceFolder}/KikitanTranslator.Console",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
